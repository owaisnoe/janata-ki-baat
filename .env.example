# Copy to .env and fill in. NEVER commit .env.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
BASE_URL=http://127.0.0.1:5000

# Database: SQLite for local dev (default), MySQL on cPanel:
# DATABASE_URL=mysql+pymysql://cpaneluser_jkb:PASSWORD@localhost/cpaneluser_jkb
DATABASE_URL=

# Admin panel password (single operator, no user accounts)
ADMIN_PASSWORD=change-me

# UPI (manual QR at launch — your own VPA)
UPI_VPA=yourname@upi
UPI_PAYEE_NAME=Janata Ki Baat

# Daily capacity cap (plan §9)
DAILY_CAP=50

# Email (cPanel SMTP). Leave SMTP_HOST empty in dev — emails are logged to console.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=letters@janatakibaat.in
SMTP_PASS=
MAIL_FROM=Janata Ki Baat <letters@janatakibaat.in>

# Cloudflare Turnstile (optional; skipped when empty — e.g. local dev)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cloudflare Web Analytics beacon token (optional)
CF_ANALYTICS_TOKEN=

# Operator identity for /about (plan §11 — real identity is the moat)
OPERATOR_NAME=Your Real Name
OPERATOR_CONTACT=letters@janatakibaat.in
OPERATOR_CITY=Tumakuru, Karnataka
